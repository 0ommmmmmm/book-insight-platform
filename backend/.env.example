# ─── Copy this to .env and fill in your values ───────────────────────────────

# Django
DJANGO_SECRET_KEY=your-very-secret-key-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (SQLite by default, uncomment for MySQL) ─────────────────────────
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=book_insight
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=3306

# ── Redis (Celery broker + cache) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI Provider: "openai" or "lmstudio" ──────────────────────────────────────
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# LM Studio (used when LLM_PROVIDER=lmstudio)
# Start LM Studio → Local Server → Load a model → Start server on port 1234
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
